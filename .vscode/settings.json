{
  // If support for Bun should be added to the default "JavaScript Debug Terminal".
  "bun.debugTerminal.enabled": true,

  // If the debugger should stop on the first line of the program.
  "bun.debugTerminal.stopOnEntry": false,

  // Glob pattern to find test files. Defaults to the value shown below.
  "bun.test.filePattern": "**/*{.test.,.spec.,_test_,_spec_}{js,ts,tsx,jsx,mts,cts,cjs,mjs}",

  // The custom script to call for testing instead of `bun test`
  "bun.test.customScript": "bun test",

  // Auto-approve routine terminal commands used while coding in this workspace.
  "chat.tools.terminal.enableAutoApprove": true,
  "chat.tools.terminal.autoApprove": {
    "pwd": true,
    "ls": true,
    "ls *": true,
    "find *": true,
    "rg *": true,
    "grep *": true,
    "sed *": true,
    "awk *": true,
    "cat *": true,
    "head *": true,
    "tail *": true,
    "wc *": true,
    "which *": true,
    "command -v *": true,

    "git status*": true,
    "git --no-pager status*": true,
    "git diff*": true,
    "git --no-pager diff*": true,
    "git log*": true,
    "git --no-pager log*": true,
    "git show*": true,
    "git --no-pager show*": true,
    "git blame*": true,
    "git --no-pager blame*": true,
    "git branch*": true,
    "git --no-pager branch*": true,
    "git rev-parse*": true,
    "git fetch*": true,
    "git pull*": true,
    "git add*": true,
    "git commit*": true,
    "git stash*": true,

    "bun": true,
    "bun *": true,
    "node *": true,
    "npm *": true,
    "npx *": true,
    "pnpm *": true,
    "yarn *": true,
    "tsc *": true,
    "eslint *": true,
    "prettier *": true,

    "mkdir *": true,
    "cp *": true,
    "mv *": true,
    "touch *": true
  },
}
